# FactGuard Production Environment Variables

# DATABASE
# For local SQLite development:
DATABASE_URL=sqlite:///./sql_app.db
# For production PostgreSQL (uncomment and adjust in Docker):
# DATABASE_URL=postgresql://user:password@db:5432/factguard

# CELERY / REDIS
REDIS_URL=redis://localhost:6379/0

# API CONFIG
PROJECT_NAME="FACTGUARD TERMINAL"
API_V1_STR="/api/v1"
DEBUG=True
CORS_ORIGINS=["*"]
